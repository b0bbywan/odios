# go-odio-api configuration
# Generated by Ansible

# Network configuration
bind: all
port: 8018

# Logging
logLevel: info

power:
  enabled: {{ (odio_api_power_can_reboot or odio_api_power_can_poweroff) | lower }}
  capabilities:
    poweroff: {{ odio_api_power_can_poweroff | lower }}
    reboot: {{ odio_api_power_can_reboot | lower }}

{% include "_systemd_block.yml.j2" %}

# Upgrade backend: reads odio-upgrade's report and drives its user units.
# progressSocket defaults to $XDG_RUNTIME_DIR/odio-api/upgrade.sock.
upgrade:
  enabled: true
  resultFile: /var/cache/odio/upgrades.json
  checkUnit: odio-check-upgrade.service
  upgradeUnit: odio-upgrade.service

# Features
zeroconf:
  enabled: true

pulseaudio:
  enabled: true
  serve_cookie: true

mpris:
  enabled: true
  timeout: 5s

{% if install_bluetooth %}
bluetooth:
  enabled: true
  timeout: 5s
  pairingTimeout: 60s
  idleTimeout: 30m
  scanTimeout: 60s
{% endif %}
