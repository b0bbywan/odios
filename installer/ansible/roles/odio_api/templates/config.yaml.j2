# go-odio-api configuration
# Generated by Ansible

# Network configuration
bind: all
port: 8018

# Logging
log_level: info

# System services to monitor (read-only)
system_services:
  - bluetooth.service
{% if install_upmpdcli %}
  - upmpdcli.service
{% endif %}

# User services to monitor and control
user_services:
  - mpd.service
  - pulseaudio.service
{% if install_spotifyd %}
  - spotifyd.service
{% endif %}
{% if install_shairport_sync %}
  - shairport-sync.service
{% endif %}
{% if install_snapclient %}
  - snapclient.service
{% endif %}

# Features
zeroconf:
  enabled: true

pulseaudio:
  enabled: true

mpris:
  enabled: true
  timeout: 5s

bluetooth:
  enabled: true
  timeout: 5s
  pairing_timeout: 60s
