# go-mpd-discplayer configuration
# Generated by Ansible

MPDConnection:
  Type: "unix"
  Address: "{{ mpd_socket_path }}"
  ReconnectWait: 5

AudioBackend: "none"
MPDLibraryFolder: "{{ mpd_music_directory }}"
MountConfig: "mpd"

{% if mpd_discplayer_gnu_email | default('') %}
gnuHelloEmail: "{{ mpd_discplayer_gnu_email }}"
gnuDbUrl: "https://gnudb.gnudb.org"
{% endif %}
