#!/bin/bash
cat <<'BANNER'
 .----------------.   .----------------.   .----------------.
| .--------------. | | .--------------. | | .--------------. |
| |     ____     | | | |              | | | |     ____     | |
| |   .'    `.   | | | |      ___     | | | |   .'    `.   | |
| |  /  .--.  \  | | | |    _|  (_)   | | | |  /  .--.  \  | |
| |  | |    | |  | | | |   / _` | |   | | | |  | |    | |  | |
| |  \  `--'  /  | | | |  | (_| | |   | | | |  \  `--'  /  | |
| |   `.____.'   | | | |   \__,_|_|   | | | |   `.____.'   | |
| '--------------' | | '--------------' | | '--------------' |
 '----------------'   '----------------'   '----------------'
BANNER

uname -snrvm

UPGRADES="/var/cache/odio/upgrades.json"
if [ -f "$UPGRADES" ]; then
    summary=$(python3 -c "
import json
with open('$UPGRADES') as f:
    data = json.load(f)
print('odio v%s' % data['current'])
if data.get('upgrade_available'):
    print('\033[1;33m⬆ Update available: %s → %s\033[0m' % (data['current'], data['latest']))
    for r in data.get('roles', []):
        print('  %s: %s → %s' % (r['name'], r['installed'], r['available']))
" 2>/dev/null)
    [ -n "$summary" ] && printf '%s\n' "$summary"
fi

PWA_URL=$(/usr/local/bin/odio-upgrade pwa-url 2>/dev/null)
[ -n "$PWA_URL" ] && printf '\n\033[1;32m📲 %s\033[0m\n' "$PWA_URL"

OS_NAME="Linux"
if [ -r /etc/os-release ]; then
    # shellcheck disable=SC1091
    . /etc/os-release
    OS_NAME="${NAME:-Linux}"
fi

echo
echo "odio - ${OS_NAME} comes with ABSOLUTELY NO WARRANTY, to the"
echo "extent permitted by applicable law."
