# go-odio-api configuration
# Generated by Ansible

# Network configuration
bind: all
port: 8018

# Logging
log_level: info

power:
  enabled: true
  capabilities:
    poweroff: true
    reboot: true

systemd:
  enabled: true
  system:
  {% if install_bluetooth %}
    - bluetooth.service
  {% endif %}
  {% if install_upmpdcli %}
    - upmpdcli.service
  {% endif %}
  user:
  {% if install_pulseaudio %}
    - pulseaudio.service
  {% endif %}
  {% if install_mpd or install_mpd_discplayer %}
    - mpd.service
  {% endif %}
  {% if install_mpd_discplayer %}
    - mpd-discplayer.service
  {% endif %}
  {% if install_shairport_sync %}
    - shairport-sync.service
  {% endif %}
  {% if install_snapclient %}
    - snapclient.service
  {% endif %}
  {% if install_spotifyd %}
    - spotifyd.service
  {% endif %}

# Features
zeroconf:
  enabled: true

pulseaudio:
  enabled: true

mpris:
  enabled: true
  timeout: 5s

{% if install_bluetooth %}
bluetooth:
  enabled: true
  timeout: 5s
  pairing_timeout: 60s
{% endif %}
