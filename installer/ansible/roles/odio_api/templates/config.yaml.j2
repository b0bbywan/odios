# go-odio-api configuration
# Generated by Ansible

# Network configuration
bind: all
port: 8018

# Logging
log_level: info

power:
  enabled: {{ (odio_api_power_can_reboot or odio_api_power_can_poweroff) | lower }}
  capabilities:
    poweroff: {{ odio_api_power_can_poweroff | lower }}
    reboot: {{ odio_api_power_can_reboot | lower }}

systemd:
  enabled: true
  system:
{% if install_bluetooth %}
    - bluetooth.service
{% endif %}
  user:
{% if install_pulseaudio %}
    - pulseaudio.service
{% endif %}
{% if install_mpd or install_mpd_discplayer %}
    - mpd.service
{% endif %}
{% if install_mpd_discplayer %}
    - mpd-discplayer.service
{% endif %}
{% if install_mympd %}
    - mympd.service
{% endif %}
{% if install_shairport_sync %}
    - shairport-sync.service
{% endif %}
{% if install_snapclient %}
    - snapclient.service
{% endif %}
{% if install_spotifyd %}
    - spotifyd.service
{% endif %}
{% if install_upmpdcli %}
    - upmpdcli.service
{% endif %}

# Features
zeroconf:
  enabled: true

pulseaudio:
  enabled: true
  serve_cookie: true

mpris:
  enabled: true
  timeout: 5s

{% if install_bluetooth %}
bluetooth:
  enabled: true
  timeout: 5s
  pairing_timeout: 60s
{% endif %}
